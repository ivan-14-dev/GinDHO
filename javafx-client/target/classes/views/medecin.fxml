<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gindho.client.controller.MedecinController" stylesheets="@../styles/style.css">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <spacing>15</spacing>
    
    <Label text="Gestion des Médecins" styleClass="section-label"/>
    
    <TableView fx:id="medecinTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="idColumn" text="ID"/>
            <TableColumn fx:id="nomColumn" text="Nom"/>
            <TableColumn fx:id="prenomColumn" text="Prénom"/>
            <TableColumn fx:id="specialiteColumn" text="Spécialité"/>
            <TableColumn fx:id="emailColumn" text="Email"/>
        </columns>
    </TableView>
    
    <HBox spacing="10">
        <Button fx:id="addBtn" text="Ajouter" styleClass="primary-button"/>
        <Button fx:id="editBtn" text="Modifier"/>
        <Button fx:id="deleteBtn" text="Supprimer"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="backBtn" text="Retour"/>
    </HBox>
</VBox>